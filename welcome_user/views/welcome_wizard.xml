<odoo>
    <record id="welcome_user" model="ir.ui.view">
        <field name="name">welcome.user.view</field>
        <field name="model">welcome.user</field>
        <field name="arch" type="xml">
            <form string="Welcome">
                <sheet>
                    <group>
                        <field name="message"/>
                    </group>
                </sheet>
                <footer>
                    <button string="continue"
                            class="btn-primary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_welcome" model="ir.actions.act_window">
        <field name="name">Welcome to ABC Company</field>
        <field name="res_model">welcome.user</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>