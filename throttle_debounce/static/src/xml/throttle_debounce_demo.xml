<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="throttle_debounce.ThrottleDebounceDemoTemplate">
        <div class="card p-4 shadow">
            <h2>Throttle vs Debounce</h2>
        </div>
        <div class="mb-3">
            <button class="btn btn-primary" t-on-click="setThrottle">Throttle</button>
            <button class="btn btn-success" t-on-click="setDebounce">Debounce</button>
        </div>
        <div class="alert alert-info">
            Current Mode: <strong><t t-esc="state.mode"/></strong>
        </div>
        <input type="text" class="form-control" placeholder="Type quickly" t-on-input="onInput"/>
        <div class="mt-3">
            Current Text: <strong><t t-esc="state.text"/></strong>
        </div>
        <div class="mt-2">
            Simulated API: <strong><t t-esc="state.calls"/> </strong>
        </div>
    </t>
</templates>