<templates xml:space="preserve">
    <t t-name="throttle_debounce.ThrottleDebounceDemoTemplate">

        <div class="throttle-demo-container">
            <div class="throttle-demo-card">

                <h2 class="throttle-demo-title">Throttle vs Debounce</h2>

                <div class="button-group">
                    <button class="btn btn-throttle" t-on-click="setThrottle">Throttle</button>
                    <button class="btn btn-debounce" t-on-click="setDebounce">Debounce</button>
                </div>

                <div class="info-box">
                    Current Mode: <strong><t t-esc="state.mode"/></strong>
                </div>

                <input type="text" placeholder="Type quickly" t-on-input="onInput"/>

                <div class="stats">
                    Text: <t t-esc="state.text"/><br/>
                    API Calls: <t t-esc="state.calls"/>
                </div>

            </div>
        </div>

    </t>
</templates>