<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="website_counter_owl.CounterTemplate">
        <div class="d-flex justify-content-center align-item-center">
            <div class="text-center">
                <h1>Counter Example</h1>
                <h2 t-esc="state.count"></h2>
                <button class="btn btn-primary me-2" t-on-click="increment">Increment</button>
                <button class="btn btn-primary" t-on-click="decrement">Decrement</button>
            </div>
        </div>
    </t>
</templates>