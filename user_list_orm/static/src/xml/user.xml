<?xml version="1.0" encoding="UTF-8" ?>
<templates>
        <t t-name="user_list_orm.Template">
            <div class="user-list-orm">
                <div class="user-list-body p-3">
                    <h4>Users list</h4>
                    <div class="table-responsive">
                        <table class="table table-bordered table-user-table">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="state.users" t-as="user" t-key="user.id">
                                    <td>
                                        <t t-if="state.editingUser and state.editingUser.id === user.id">
                                            <input type="text" class="form-control" t-model="state.editingUser.name"/>
                                        </t>
                                        <t t-else="">
                                            <t t-esc="user.name"/>
                                        </t>
                                    </td>
                                    <td>
                                        <t t-if="state.editingUser and state.editingUser.id === user.id">
                                            <input type="text" class="form-control" t-model="state.editingUser.email"/>
                                        </t>
                                        <t t-else="">
                                            <t t-esc="user.email"/>
                                        </t>
                                    </td>
                                    <td class="text-center ">
                                        <t t-if="state.editingUser and state.editingUser.id === user.id">
                                            <button type="button" class="btn btn-primary btn-sm me-2" t-on-click="saveUser">Save</button>
                                            <button type="button" class="btn btn-secondary btn-sm me-2" t-on-click="() => state.editingUser = null">Cancel</button>
                                        </t>
                                        <t t-else="">
                                            <button type="button" string="Edit" class="btn btn-primary btn-sm me-2" t-on-click="() => this.editUser(user)"><i class="fa fa-pencil"/>Edit</button>
                                            <button type="button" string="Delete" class="btn btn-danger btn-sm " t-on-click="() => this.deleteUser(user)"><i class="fa fa-trash"/>Delete</button>
                                        </t>
                                    </td>
                                </tr>
                            </tbody>

                        </table>
                    </div>
                </div>

            </div>

        </t>

</templates>