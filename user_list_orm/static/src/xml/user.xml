<?xml version="1.0" encoding="UTF-8" ?>
<templates>
        <t t-name="user_list_orm.Template">
            <div class="user-list-orm">
                <div class="user-list-body p-3">
                    <h4>Users list</h4>
                    <div class="table-responsive">
                        <table class="table table-bordered table-user-table">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="state.users" t-as="user" t-key="user.id">
                                    <td>
                                        <t t-esc="user.name"/>
                                    </td>
                                    <td>
                                        <t t-esc="user.email"/>
                                    </td>
                                    <td class="text-center ">
                                        <button type="button" string="Edit" class="btn btn-primary btn-sm me-2"><i class="fa fa-pencil"/>Edit</button>
                                        <button type="button" string="Delete" class="btn btn-danger btn-sm"><i class="fa fa-trash"/>Delete</button>
                                    </td>
                                </tr>
                            </tbody>

                        </table>
                    </div>
                </div>

            </div>

        </t>

</templates>